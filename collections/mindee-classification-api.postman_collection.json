      "name": "Classification",
      "description": {
        "content": "Classify documents by type so they can be routed to the appropriate downstream extraction model.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "c2efdedd-bf6e-406a-8d75-9224300e8368",
          "name": "Send A File For A Classification Utility Inference",
          "request": {
            "name": "Send A File For A Classification Utility Inference",
            "description": {
              "content": "Send a file to the asynchronous processing queue for a classification utility inference.\n\nResults can be retrieved in two ways:\n* Loop on the `polling_url` endpoint in the response until the status\n  is `Processed` or `Failed` (polling).\n* Use a webhook to be notified when the inference is finished.\n  Webhooks can be configured on the platform on a per-model basis.\n\nInferences taking longer than 590 seconds will time out.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v2",
                "products",
                "classification",
                "enqueue"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "apikey",
              "apikey": [
                {
                  "key": "key",
                  "value": "Authorization"
                },
                {
                  "key": "value",
                  "value": "{{apiKey}}"
                },
                {
                  "key": "in",
                  "value": "header"
                }
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "model_id",
                  "value": "<uuid4>",
                  "type": "text",
                  "description": "(Required) Model ID to use for the inference."
                },
                {
                  "key": "file",
                  "value": "<binary>",
                  "type": "text",
                  "description": "Upload a file as bytes. Required if `url` is not provided."
                },
                {
                  "key": "url",
                  "value": "<uri>",
                  "type": "text",
                  "description": "Download the file from a URL, must be secure (HTTPS) and publicly available. Required if `file` is not provided."
                },
                {
                  "key": "file_base64",
                  "value": "<string>",
                  "type": "text",
                  "description": "Upload a file as a base 64 string. Used as an alternative to `file`. *Not recommended*, for specific use only."
                },
                {
                  "key": "webhook_ids",
                  "value": "[\"<uuid4>\",\"<uuid4>\"]",
                  "type": "text",
                  "description": "Webhook IDs to call after all processing is finished. If empty, no webhooks will be used. Can be a list or comma-separated string."
                },
                {
                  "key": "filename",
                  "value": "<string>",
                  "type": "text",
                  "description": "Optional filename to associate with the uploaded or fetched file."
                },
                {
                  "key": "alias",
                  "value": "<string>",
                  "type": "text",
                  "description": "Optional: a free-form string to tag the request with your own identifier. For example, an internal document ID, reference number, or database key. If set, it will be included in the job and result responses."
                }
              ]
            }
